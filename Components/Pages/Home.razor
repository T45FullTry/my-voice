@page "/"
@inject IVoiceRecordingService VoiceService
@inject VoiceDbContext Db

<PageTitle>Home - my Voice</PageTitle>

<h1>Welcome to my Voice</h1>

<div class="row">
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">📊 Your Stats</h5>
                <p class="card-text">
                    <strong>@recordingCount</strong> recordings<br />
                    <strong>@totalDuration</strong> total minutes
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">🎯 Quick Actions</h5>
                <a href="record" class="btn btn-primary">Record New</a>
                <a href="library" class="btn btn-outline-secondary">View Library</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">📁 Storage</h5>
                <p class="card-text">
                    Audio files stored in browser (IndexedDB)<br />
                    Metadata stored in SQLite database
                </p>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <div class="input-group">
        <span class="input-group-text">🔍</span>
        <input @bind="searchTerm" @bind:event="oninput" class="form-control" placeholder="Search recordings..." />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button @onclick="ClearSearch" class="btn btn-outline-secondary" type="button">Clear</button>
        }
    </div>
</div>

@if (filteredRecordings.Any())
{
    <h3 class="mt-4">Recent Recordings</h3>
    <div class="list-group">
        @foreach (var recording in filteredRecordings.Take(5))
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@recording.Title</strong><br />
                    <small class="text-muted">@recording.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                    @if (!string.IsNullOrEmpty(recording.Description))
                    {
                        <br /><small class="text-muted">@recording.Description</small>
                    }
                </div>
                <audio controls class="me-2">
                    <source src="@($"data:audio/webm;base64,{Convert.ToBase64String(recording.AudioData)}")" type="audio/webm" />
                    Your browser does not support audio.
                </audio>
            </div>
        }
    </div>
}

@code {
    private int recordingCount = 0;
    private double totalDuration = 0;
    private List<VoiceRecording> recentRecordings = new();
    private List<VoiceRecording> filteredRecordings = new();
    private string? searchTerm;

    protected override async Task OnInitializedAsync()
    {
        recentRecordings = await Db.VoiceRecordings
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();
        
        recordingCount = recentRecordings.Count;
        totalDuration = recentRecordings.Sum(r => r.DurationSeconds) / 60.0;
        filteredRecordings = recentRecordings;
    }

    private void FilterRecordings()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredRecordings = recentRecordings;
        }
        else
        {
            filteredRecordings = recentRecordings
                .Where(r => r.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                           (r.Tags != null && r.Tags.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                           (r.Description != null && r.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = null;
        FilterRecordings();
    }
}
