@page "/record"
@inject IJSRuntime JS
@inject VoiceDbContext Db
@inject NavigationManager Navigation

<PageTitle>Record - my Voice</PageTitle>

<h1>🎤 Record Your Voice</h1>

<div class="card">
    <div class="card-body text-center">
        <div class="mb-3">
            <button @onclick="StartRecording" disabled="@isRecording" class="btn btn-lg btn-success me-2">
                <span class="bi bi-mic-fill"></span> Start Recording
            </button>
            <button @onclick="StopRecording" disabled="!isRecording" class="btn btn-lg btn-danger">
                <span class="bi bi-stop-circle-fill"></span> Stop Recording
            </button>
        </div>

        @if (isRecording)
        {
            <div class="alert alert-info">
                <span class="spinner-border spinner-border-sm" role="status"></span>
                Recording... @recordingSeconds seconds
            </div>
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-@(isError ? "danger" : "success")">
                @statusMessage
            </div>
        }

        @if (audioBlob != null)
        {
            <div class="mt-3">
                <h5>Preview:</h5>
                <audio controls>
                    <source src="@audioUrl" type="audio/webm" />
                    Your browser does not support audio.
                </audio>
            </div>

            <div class="mt-3">
                <input @bind="title" class="form-control mb-2" placeholder="Recording title" />
                <textarea @bind="description" class="form-control mb-2" placeholder="Description (optional)" rows="3"></textarea>
                <input @bind="tags" class="form-control mb-2" placeholder="Tags (comma-separated)" />
                <button @onclick="SaveRecording" class="btn btn-primary">
                    <span class="bi bi-save-fill"></span> Save to Library
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool isRecording;
    private int recordingSeconds;
    private string? statusMessage;
    private bool isError;
    private string? title;
    private string? description;
    private string? tags;
    private byte[]? audioBlob;
    private string? audioUrl;
    private System.Timers.Timer? timer;
    private DotNetObjectReference<RecordComponent>? dotNetRef;

    protected override void OnInitialized()
    {
        dotNetRef = DotNetObjectReference.Create(this);
    }

    private async Task StartRecording()
    {
        try
        {
            await JS.InvokeVoidAsync("startAudioRecording", dotNetRef);
            isRecording = true;
            recordingSeconds = 0;
            statusMessage = null;
            audioBlob = null;
            audioUrl = null;

            timer = new System.Timers.Timer(1000);
            timer.Elapsed += (s, e) => InvokeAsync(() => recordingSeconds++);
            timer.Start();
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to start recording: {ex.Message}";
        }
    }

    private async Task StopRecording()
    {
        try
        {
            timer?.Stop();
            timer?.Dispose();
            
            var blob = await JS.InvokeAsync<byte[]>("stopAudioRecording");
            audioBlob = blob;
            audioUrl = $"data:audio/webm;base64,{Convert.ToBase64String(blob)}";
            isRecording = false;
            statusMessage = "Recording complete! Add a title and save.";
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to stop recording: {ex.Message}";
        }
    }

    private async Task SaveRecording()
    {
        if (audioBlob == null || string.IsNullOrWhiteSpace(title))
        {
            isError = true;
            statusMessage = "Please provide a title for your recording.";
            return;
        }

        try
        {
            var recording = new VoiceRecording
            {
                Title = title.Trim(),
                Description = description?.Trim(),
                Tags = tags?.Trim() ?? "",
                AudioData = audioBlob,
                DurationSeconds = recordingSeconds,
                CreatedAt = DateTime.UtcNow
            };

            Db.VoiceRecordings.Add(recording);
            await Db.SaveChangesAsync();

            statusMessage = "Recording saved successfully!";
            isError = false;
            audioBlob = null;
            audioUrl = null;
            title = null;
            description = null;
            tags = null;

            // Navigate to library after short delay
            await Task.Delay(1500);
            Navigation.NavigateTo("library");
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to save: {ex.Message}";
        }
    }

    public void OnRecordingComplete(byte[] audioData)
    {
        audioBlob = audioData;
        InvokeAsync(StateHasChanged);
    }

    protected override void Dispose()
    {
        timer?.Dispose();
        dotNetRef?.Dispose();
        base.Dispose();
    }
}
