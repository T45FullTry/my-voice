@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">
                    <span class="navbar-toggler-icon"></span>
                    🎤 my Voice
                </a>
            </div>
        </div>
        <div class="nav-scrollable">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="record">
                        <span class="bi bi-mic-fill" aria-hidden="true"></span> Record
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="library">
                        <span class="bi bi-collection-play-fill" aria-hidden="true"></span> Library
                    </NavLink>
                </div>
            </nav>
        </div>
    </aside>

    <main>
        <div class="top-row ps-3 navbar navbar-light">
            <div class="container-fluid">
                <span class="navbar-brand">Your Voice Reference Library</span>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
