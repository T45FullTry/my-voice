@page "/record"
@inject IJSRuntime JS
@inject VoiceDbContext Db
@inject NavigationManager Navigation

<PageTitle>Record - my Voice</PageTitle>

<h1>🎤 Record Your Voice</h1>

<div class="card">
    <div class="card-body">
        <div class="text-center mb-3">
            <div class="btn-group w-100" role="group">
                <button @onclick="StartRecording" disabled="@isRecording" class="btn btn-lg btn-success flex-fill">
                    <span class="bi bi-mic-fill"></span> Start
                </button>
                <button @onclick="StopRecording" disabled="@(!isRecording)" class="btn btn-lg btn-danger flex-fill">
                    <span class="bi bi-stop-circle-fill"></span> Stop
                </button>
            </div>
        </div>

        @if (isRecording)
        {
            <div class="alert alert-info">
                <span class="spinner-border spinner-border-sm" role="status"></span>
                Recording... @recordingSeconds seconds
            </div>
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-@(isError ? "danger" : "success")">
                @statusMessage
            </div>
        }

        @if (audioBlob != null)
        {
            <div class="mt-3">
                <h5>Preview:</h5>
                <audio controls class="w-100 mb-3">
                    <source src="@audioUrl" type="audio/webm" />
                    Your browser does not support audio.
                </audio>
            </div>

            <div class="mt-3">
                <input @bind="title" class="form-control mb-2" placeholder="Recording title (required)" />
                <textarea @bind="description" class="form-control mb-2" placeholder="Description (optional)" rows="3"></textarea>
                <input @bind="tags" class="form-control mb-2" placeholder="Tags (comma-separated)" />
                <button @onclick="SaveRecording" class="btn btn-primary w-100">
                    <span class="bi bi-save-fill"></span> Save to Library
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool isRecording = false;
    private int recordingSeconds;
    private string? statusMessage;
    private bool isError;
    private string? title;
    private string? description;
    private string? tags;
    private byte[]? audioBlob;
    private string? audioUrl;
    private PeriodicTimer? timer;
    private DotNetObjectReference<Record>? dotNetRef;

    protected override void OnInitialized()
    {
        dotNetRef = DotNetObjectReference.Create(this);
    }

    private async Task StartRecording()
    {
        try
        {
            isError = false;
            statusMessage = "Requesting microphone access...";
            await InvokeAsync(StateHasChanged);

            await JS.InvokeVoidAsync("startAudioRecording", dotNetRef);
            isRecording = true;
            recordingSeconds = 0;
            statusMessage = null;
            audioBlob = null;
            audioUrl = null;
            await InvokeAsync(StateHasChanged);

            // Use PeriodicTimer instead of System.Timers.Timer for better async handling
            timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            _ = UpdateRecordingTime();
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to start recording: {ex.Message}";
            isRecording = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdateRecordingTime()
    {
        try
        {
            while (isRecording && timer != null)
            {
                await timer.WaitForNextTickAsync();
                if (isRecording)
                {
                    recordingSeconds++;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Timer was disposed
        }
    }

    private async Task StopRecording()
    {
        try
        {
            isRecording = false;
            timer?.Dispose();
            statusMessage = "Processing recording...";
            await InvokeAsync(StateHasChanged);

            // Call the JS function - returns just "success"
            var result = await JS.InvokeAsync<string>("stopAudioRecording");

            if (result != "success")
            {
                throw new Exception("Recording stopped but data was not properly saved");
            }

            // Retrieve the base64 audio from sessionStorage
            var base64Audio = await JS.InvokeAsync<string>("getRecordedAudio");

            if (string.IsNullOrEmpty(base64Audio))
            {
                throw new Exception("No audio data found in storage");
            }

            try
            {
                // Convert base64 to byte array
                audioBlob = Convert.FromBase64String(base64Audio);
                audioUrl = $"data:audio/webm;base64,{base64Audio}";

                statusMessage = "Recording complete! Add a title and save.";
                isError = false;
            }
            catch (FormatException)
            {
                throw new Exception("Failed to process audio data locally. Please try recording again.");
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to stop recording: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveRecording()
    {
        if (audioBlob == null || string.IsNullOrWhiteSpace(title))
        {
            isError = true;
            statusMessage = "Please provide a title for your recording.";
            return;
        }

        try
        {
            VoiceRecording recording = new VoiceRecording
            {
                Title = title.Trim(),
                Description = description?.Trim(),
                Tags = tags?.Trim() ?? "",
                AudioData = audioBlob,
                DurationSeconds = recordingSeconds,
                CreatedAt = DateTime.UtcNow
            };

            Db.VoiceRecordings.Add(recording);
            await Db.SaveChangesAsync();

            statusMessage = "Recording saved successfully!";
            isError = false;
            audioBlob = null;
            audioUrl = null;
            title = null;
            description = null;
            tags = null;
            recordingSeconds = 0;
            await InvokeAsync(StateHasChanged);

            // Navigate to library after short delay
            await Task.Delay(1500);
            Navigation.NavigateTo("library");
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Failed to save: {ex.Message}";
        }
    }

    [JSInvokable]
    public async Task OnRecordingComplete(byte[] audioData)
    {
        audioBlob = audioData;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        timer?.Dispose();
        dotNetRef?.Dispose();
    }
}
