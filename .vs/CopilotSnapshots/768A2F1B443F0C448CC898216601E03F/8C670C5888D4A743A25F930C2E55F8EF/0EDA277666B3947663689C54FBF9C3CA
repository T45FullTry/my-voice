@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    
    <aside class="sidebar @sidebarClass">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">
                    🎤 my Voice
                </a>
            </div>
        </div>
        <div class="nav-scrollable">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseSidebarOnMobile">
                        <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="record" @onclick="CloseSidebarOnMobile">
                        <span class="bi bi-mic-fill" aria-hidden="true"></span> Record
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="library" @onclick="CloseSidebarOnMobile">
                        <span class="bi bi-collection-play-fill" aria-hidden="true"></span> Library
                    </NavLink>
                </div>
            </nav>
        </div>
    </aside>

    <main>
        <div class="top-row ps-3 navbar navbar-light">
            <div class="container-fluid">
                <button class="menu-toggle" @onclick="ToggleSidebar" aria-label="Toggle menu">
                    ☰
                </button>
                <span class="navbar-brand">Your Voice Reference Library</span>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private bool sidebarOpen = false;
    private string sidebarClass => sidebarOpen ? "open" : "";

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebarOnMobile()
    {
        // Close sidebar on mobile when a nav link is clicked
        sidebarOpen = false;
    }
}
