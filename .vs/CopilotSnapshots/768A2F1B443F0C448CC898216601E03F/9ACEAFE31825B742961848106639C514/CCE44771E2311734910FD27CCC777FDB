<Routes>
    <Found>
        <RouteView RouteData="@context.RouteData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@context.RouteData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Routes>
